# ============================================
# 后端环境变量配置
# ============================================

# 服务器端口
PORT=3001

# 通义千问 API 配置（用于图片风格化）
QWEN_API_KEY=your_qwen_api_key_here
QWEN_TEXT_MODEL=qwen-plus

# Supabase 配置（可选，用于云端同步）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
ENABLE_SUPABASE_SYNC=false
